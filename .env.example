# Copy this file to `.env` and fill in values for your environment.
# The codebase loads these with python-dotenv. Do not quote values unless needed.
#
# Notes:
# - `./layerd` must exist in the project root and be executable.
# - `ROOT_PATH` is not read from `.env`; use `python app.py --root-path ...` instead.
# - `LAYER_GRPC_URL` is not currently read by the code and is intentionally omitted.

# Required Tellor Layer endpoints
TELLOR_LAYER_RPC_URL=https://node-mainnet.tellorlayer.com/rpc/
LAYER_API_URL=https://node-mainnet.tellorlayer.com

# Required Ethereum RPC endpoint
# Use an archive-capable RPC if you plan to backfill historical snapshots.
ETHEREUM_RPC_URL=https://your-ethereum-rpc.example

# Required contracts for TRB and bridge balance collection
TRB_CONTRACT=0x88dF592F8eb5D7Bd38bFeF7dEb0fBc02cf3778a0
CURRENT_BRIDGE_CONTRACT=0x6ec401744008f4B018Ed9A36f76e6629799Ee50E

# Optional legacy Bridge V1 contract.
# In this project, `bridge_balance_trb` refers to this old bridge balance.
OLD_BRIDGE_CONTRACT_1=0x5589e306b1920F009979a50B88caE32aecD471E4

# Optional explicit Bridge V2 contract.
# If unset, the code falls back to `CURRENT_BRIDGE_CONTRACT`.
TRBBRIDGEV2_CONTRACT_ADDRESS=0x6ec401744008f4B018Ed9A36f76e6629799Ee50E

# Optional collector settings
CURRENT_DATA_INTERVAL=300
DISCORD_WEBHOOK_URL=DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/0000000000000000000000000000000000000000

# Optional block size collector tuning (run_block_size_collector.py)
# These can also be overridden with CLI flags.
BLOCK_SIZE_ALERT_WINDOW=100      # rolling window (blocks) for z-score baseline
BLOCK_SIZE_ALERT_THRESHOLD=3.0   # z-score threshold for anomaly alerts
BLOCK_SIZE_ALERT_COOLDOWN=300    # seconds between repeated alerts for the same metric

# Optional CSV inputs used by unified historical bridge calculations.
# The defaults below match the repository examples.
BRIDGE_DEPOSITS_CSV_PATH=example_bridge_deposits.csv
BRIDGE_WITHDRAWALS_CSV_PATH=example_bridge_withdrawals.csv
